khoadangnguyen.com {
    encode gzip
    reverse_proxy frontend:3000

    header {
        X-Frame-Options "SAMEORIGIN"
        X-Content-Type-Options "nosniff"
        X-XSS-Protection "1; mode=block"
        Referrer-Policy "strict-origin-when-cross-origin"
        Strict-Transport-Security "max-age=31536000; includeSubDomains"
    }
}

admin.khoadangnguyen.com {
    encode gzip
    reverse_proxy admin:3001

    header {
        X-Frame-Options "DENY"
        X-Content-Type-Options "nosniff"
        X-XSS-Protection "1; mode=block"
        Referrer-Policy "strict-origin-when-cross-origin"
        Strict-Transport-Security "max-age=31536000; includeSubDomains"
        Content-Security-Policy "default-src 'self'; script-src 'self' 'unsafe-inline'; style-src 'self' 'unsafe-inline'; img-src 'self' data: https:; font-src 'self';"
    }
}

api.khoadangnguyen.com {
    encode gzip
    reverse_proxy backend:8080

    header {
        X-Frame-Options "DENY"
        X-Content-Type-Options "nosniff"
        Access-Control-Allow-Origin "https://khoadangnguyen.com"
        Access-Control-Allow-Methods "GET, POST, PUT, DELETE, OPTIONS"
        Access-Control-Allow-Headers "Authorization, Content-Type"
    }
}
