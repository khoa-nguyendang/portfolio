{
  "name": "portfolio-frontend",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "node server.js",
    "dev:vite": "vite",
    "build": "npm run build:client && npm run build:server && cp server.js dist/server.js",
    "build:client": "vite build --outDir dist/client",
    "build:server": "vite build --ssr src/entry-server.tsx --outDir dist/server",
    "preview": "NODE_ENV=production node dist/server.js",
    "serve": "NODE_ENV=production node dist/server.js"
  },
  "dependencies": {
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-router-dom": "^7.1.0",
    "lucide-react": "^0.469.0",
    "express": "^4.21.0",
    "compression": "^1.7.5",
    "sirv": "^3.0.0"
  },
  "devDependencies": {
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@types/express": "^5.0.0",
    "@types/compression": "^1.7.5",
    "@types/node": "^22.10.0",
    "typescript": "^5.7.0",
    "vite": "^6.0.0",
    "@vitejs/plugin-react": "^4.3.0",
    "tailwindcss": "^4.0.0",
    "@tailwindcss/vite": "^4.0.0",
    "autoprefixer": "^10.4.0",
    "postcss": "^8.4.0"
  }
}
