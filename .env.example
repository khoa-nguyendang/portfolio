# ──────────────────────────────────────────────────────────────
# Portfolio - Environment Variables
# Copy to .env and fill in actual values for local development.
# Production uses Doppler for secret injection.
# ──────────────────────────────────────────────────────────────

# ── Database ──────────────────────────────────────────────────
# PostgreSQL connection string
DATABASE_URL=postgres://portfolio:portfolio@localhost:5432/portfolio?sslmode=disable

# ── Server ────────────────────────────────────────────────────
# Port the backend API listens on
SERVER_PORT=8080

# ── Authentication ────────────────────────────────────────────
# JWT signing secret (change in production!)
JWT_SECRET=dev-secret-change-me

# Default admin account (seeded on first run)
ADMIN_EMAIL=admin@khoadangnguyen.com
ADMIN_PASSWORD=changeme

# ── CORS ──────────────────────────────────────────────────────
# Comma-separated list of allowed origins
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001

# ── Email (Resend) ───────────────────────────────────────────
# API key from https://resend.com
RESEND_API_KEY=re_dev_placeholder
# Sender email address (must be verified in Resend)
RESEND_FROM_EMAIL=noreply@khoadangnguyen.com

# ── LLM API (for translations) ───────────────────────────────
# OpenAI-compatible API endpoint for post translation
LLM_API_URL=
# API key for the LLM service
LLM_API_KEY=

# ── Frontend ──────────────────────────────────────────────────
# Backend URL for the frontend API proxy (internal Docker network)
FRONTEND_URL=http://frontend:3000

# ── Cloudflare CDN Cache Purge (optional) ─────────────────────
# Zone ID from Cloudflare dashboard → Overview → right sidebar
CF_ZONE_ID=
# API token with "Cache Purge" permission for the zone
CF_API_TOKEN=
# Public site hostname
SITE_HOST=khoadangnguyen.com

# ── Container Registry (CI/CD only) ─────────────────────────
# Vultr Container Registry credentials
VCR_PUSH_USERNAME=
VCR_PUSH_PASSWORD=

# ── Deployment (CI/CD only) ─────────────────────────────────
# Image tag for production docker compose
IMAGE_TAG=latest
